{
  "name": "sportsapp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sportsapp/api",
    "dev:api": "npm run dev --workspace @sportsapp/api",
    "dev:mobile": "npm run start --workspace @sportsapp/mobile",
    "build": "npm run build --workspace @sportsapp/api && npm run build --workspace @sportsapp/mobile",
    "test": "npm run test --workspace @sportsapp/api",
    "lint": "npm run lint --workspace @sportsapp/api && npm run lint --workspace @sportsapp/mobile",
    "db:migrate": "node infra/scripts/run-migration.mjs"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "dotenv": "^16.5.0",
    "pg": "^8.14.1"
  }
}
